<?xml version="1.0" encoding="utf-8"?>
<keyboard name="UOINDL" script="latin">
  <row>
    <key c="u" nw="~" ne="@" sw="`" se="#"/>
    <key c="o" nw="$" ne="&quot;" sw="%" se="'"/>
    <key c="i" nw="^" ne="(" sw="&amp;" se=")" anticircle="7" indication="⁷"/>
    <key c="n" ne="z" sw="v" anticircle="8" indication="⁸"/>
    <key c="d" ne="_" sw="p" se="-" anticircle="9" indication="⁹"/>
    <key c="l" nw="*" ne="+" sw="j" se="="/>
    <key c=":str symbol='lrv':'lrvideckis'" nw="lukevideckis" ne="@gmail" sw="codeforces" se=".com"/>
  </row>
  <row>
    <key c="g" ne="esc" se="tab"/>
    <key c="t" nw="q" se="k"/>
    <key c="a" anticircle="4" indication="⁴"/>
    <key c="r" ne="x" sw="c" anticircle="5" indication="⁵"/>
    <key c="s" nw="{" ne="}" sw="[" se="]" anticircle="6" indication="⁶"/>
    <key c="m" nw=":" ne="|" sw=";" se="\\"/>
    <key c="switch_numeric"/>
  </row>
  <row>
    <key c="shift" ne="capslock"/>
    <key c="y" anticircle="0" indication="⁰"/>
    <key c="e" nw="&lt;" ne="&gt;" sw="," se="." anticircle="1" indication="¹"/>
    <key c="h" ne="b" sw="f" anticircle="2" indication="²"/>
    <key c="w" sw="!" ne="?" se="/" anticircle="3" indication="³"/>
    <key width="2" c="backspace"/>
  </row>
  <row height="0.95">
    <key width="0.93" c="ctrl" se="fn"/>
    <key width="0.93" c="left" w="home" n="up" s="down"/>
    <key width="0.93" c="right" e="end"/>
    <key width="1.42" c="space"/>
    <key width="0.93" c="switch_forward" w="undo" e="redo" n="config" s="switch_emoji"/>
    <key width="0.93" c="selectAll" e="switch_clipboard" n="copy" s="paste"/>
    <key width="0.93" c="enter" n="action"/>
  </row>
</keyboard>
